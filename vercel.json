{
    "version": 2,
    "builds": [
        {
            "src": "onlineVotingSystem/wsgi.py",
            "use": "@vercel/python",
            "config": {
                "maxLambdaSize": "50mb",
                "runtime": "python3.11"
            }
        },
        {
            "src": "poll/static/**",
            "use": "@vercel/static"
        }
    ],
    "routes": [
        {
            "src": "/static/(.*)",
            "dest": "poll/static/$1"
        },
        {
            "src": "/(.*)",
            "dest": "onlineVotingSystem/wsgi.py"
        }
    ]
}
